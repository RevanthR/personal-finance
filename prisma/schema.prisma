// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth ────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  USER
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  role              Role               @default(USER)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  planType          String             @default("FREE")  // FREE | WEEKLY | MONTHLY | QUARTERLY | YEARLY
  planExpiry        DateTime?
  trialEndsAt       DateTime?
  accounts          Account[]
  sessions          Session[]
  months            Month[]
  templates         LineItemTemplate[]
  chitFunds         ChitFund[]
  creditCards       CreditCard[]
  receivables       Receivable[]
  pushSubscriptions PushSubscription[]
  payments          Payment[]
  customCategories  CustomCategory[]
  gmailConnection   GmailConnection?
  parsedTransactions ParsedTransaction[]
  gmailSeenMessages  GmailSeenMessage[]
}

// User-defined expense categories, reused (not retyped) across templates
// and ad-hoc items so a name can't drift into near-duplicates over time.
model CustomCategory {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  createdAt  DateTime           @default(now())
  templates  LineItemTemplate[]
  adHocItems AdHocItem[]

  @@unique([userId, name])
}

model Payment {
  id                String   @id @default(cuid())
  userId            String
  razorpayOrderId   String   @unique
  razorpayPaymentId String?
  planType          String   // WEEKLY | MONTHLY | QUARTERLY | YEARLY
  amount            Int      // paise
  status            String   @default("CREATED") // CREATED | CAPTURED | FAILED
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Finance Core ─────────────────────────────────────────────────────────────

enum Category {
  HOUSE_MAINTENANCE
  LOAN
  CHIT_FUND
  CREDIT_CARD
  SAVINGS
  PERSONAL
  MISCELLANEOUS
  SALARY
  FREELANCE
  RENTAL
  BUSINESS
  INVESTMENTS
  OTHER_INCOME
}

enum Frequency {
  MONTHLY
  YEARLY
}

enum TemplateType {
  EXPENSE
  INCOME
}

enum AdHocType {
  INCOME
  EXPENSE
}

// Recurring line item template — one per type of payment
model LineItemTemplate {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  category         Category
  customCategory   String?
  customCategoryId String?
  customCategoryRef CustomCategory? @relation(fields: [customCategoryId], references: [id], onDelete: SetNull)
  amount           Float
  isFixed          Boolean        @default(true)
  dueDateDay       Int?
  isActive         Boolean        @default(true)
  foreClosedOn     DateTime?
  foreCloseAmount  Float?
  pendingAmount    Float?
  pendingFromMonth Int?
  pendingFromYear  Int?
  statementDay     Int?
  frequency        Frequency      @default(MONTHLY)
  dueMonth         Int?
  templateType     TemplateType   @default(EXPENSE)
  endsOnMonth      Int?
  endsOnYear       Int?
  sortOrder        Int            @default(0)
  loanOriginalPrincipal   Float?
  loanInterestRate        Float?
  loanRateType            String?   // "FIXED" | "FLOATING"
  loanStartDate           DateTime?
  loanOutstandingOverride Float?
  createdAt        DateTime       @default(now())
  entries          MonthlyEntry[]
  chitFund         ChitFund?
  creditCard       CreditCard?
  adHocCharges     AdHocItem[]
}

// One record per calendar month per user
model Month {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  month           Int
  year            Int
  salaryIncome    Float          @default(0)
  freelanceIncome Float          @default(0)
  otherIncome     Float          @default(0)
  isPopulated     Boolean        @default(false)
  createdAt       DateTime       @default(now())
  entries         MonthlyEntry[]
  adHocItems      AdHocItem[]
  receivables     Receivable[]

  @@unique([userId, month, year])
}

// Instance of a template for a specific month
model MonthlyEntry {
  id              String           @id @default(cuid())
  monthId         String
  month           Month            @relation(fields: [monthId], references: [id], onDelete: Cascade)
  templateId      String
  template        LineItemTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  amount          Float
  isPaid          Boolean          @default(false)
  paidOn          DateTime?
  paidAmount      Float?
  cashbackAmount  Float?
  notes           String?
  statementAmount Float?
  billedAmount    Float?           // CC only: obligation at month open; used for carry-forward instead of amount
  createdAt       DateTime         @default(now())

  @@unique([monthId, templateId])
}

// Chit fund details — linked 1:1 to a LineItemTemplate
model ChitFund {
  id                    String           @id @default(cuid())
  templateId            String           @unique
  template              LineItemTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId                String
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalValue            Float
  durationMonths        Int
  startDate             DateTime
  monthlyUnliftedAmount Float
  monthlyLiftedAmount   Float?
  isLifted              Boolean          @default(false)
  liftedOn              DateTime?
  liftedAmount          Float?
  liftedUsedFor         String?
  accumulatedSavings    Float            @default(0)
  endDate               DateTime?
  createdAt             DateTime         @default(now())
}

// Credit card — linked 1:1 to a LineItemTemplate of category CREDIT_CARD
model CreditCard {
  id           String           @id @default(cuid())
  templateId   String           @unique
  template     LineItemTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  bank         String?
  network      String?          // "Visa" | "Mastercard" | "Rupay" | "Amex"
  last4        String?          // last 4 digits, used to auto-match Gmail-imported transactions
  createdAt    DateTime         @default(now())
}

// One-off income or expense for a month
model AdHocItem {
  id                String          @id @default(cuid())
  monthId           String
  month             Month           @relation(fields: [monthId], references: [id], onDelete: Cascade)
  name              String
  amount            Float
  type              AdHocType
  category          Category?
  customCategory    String?
  customCategoryId  String?
  customCategoryRef CustomCategory? @relation(fields: [customCategoryId], references: [id], onDelete: SetNull)
  // Authoritative link for CC statement math — replaces parsing the card
  // name out of the notes field, which broke if notes became user-editable.
  ccTemplateId      String?
  ccTemplate        LineItemTemplate? @relation(fields: [ccTemplateId], references: [id], onDelete: SetNull)
  date              DateTime
  notes             String?
  createdAt         DateTime        @default(now())
}

enum ReceivableCategory {
  INVESTMENT
  PERSONAL_LOAN
  CUSTOM
}

enum ReceivableStatus {
  PENDING
  RECEIVED
}

model Receivable {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        ReceivableCategory
  customCategory  String?
  description     String
  expectedAmount  Float
  expectedDate    DateTime?
  status          ReceivableStatus   @default(PENDING)
  receivedAmount  Float?
  receivedDate    DateTime?
  receivedMonthId String?
  receivedMonth   Month?             @relation(fields: [receivedMonthId], references: [id])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

// Web Push subscription per device
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  label     String?
  createdAt DateTime @default(now())
}

// ─── Gmail transaction import ──────────────────────────────────────────────

// One per user — opt-in connection storing the OAuth token used to read
// (read-only) bank transaction alert emails. Separate from the NextAuth
// Account record so the sensitive gmail.readonly scope is only ever
// requested when a user explicitly opts in from Settings, not at sign-in.
model GmailConnection {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  email        String?
  accessToken  String    @db.Text
  refreshToken String    @db.Text
  tokenExpiry  DateTime
  lastSyncAt   DateTime?
  connectedAt  DateTime  @default(now())
  historyId       String?
  watchExpiration DateTime?
}

enum ParsedTransactionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ParsedTransactionPaymentMethod {
  CREDIT_CARD
  UPI
  DEBIT_CARD
  OTHER
}

// A bank email Gemini identified as a transaction, awaiting the user's
// review before it becomes a real AdHocItem (and, for credit cards, a
// MonthlyEntry statement-math effect).
model ParsedTransaction {
  id                     String                          @id @default(cuid())
  userId                 String
  user                   User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  gmailMessageId         String
  bank                   String
  amount                 Float
  originalCurrency       String?
  originalAmount         Float?
  merchant               String?
  last4                  String?
  date                   DateTime
  transactionTime        String?
  emailReceivedAt        DateTime?
  rawSnippet             String
  status                 ParsedTransactionStatus         @default(PENDING)
  paymentMethod          ParsedTransactionPaymentMethod  @default(CREDIT_CARD)
  suggestedCcTemplateId  String?
  suggestedSubcategory   String?
  createdAt              DateTime                        @default(now())

  @@unique([userId, gmailMessageId])
}

// Every Gmail message the sync has ever inspected, whether or not it turned
// into a ParsedTransaction — prevents re-fetching and re-sending the same
// non-transaction email (promos, OTPs, statements) to Gemini on every sync
// for as long as it stays inside the search window.
model GmailSeenMessage {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gmailMessageId String
  createdAt      DateTime @default(now())

  @@unique([userId, gmailMessageId])
}
