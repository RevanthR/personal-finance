// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth ────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  USER
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  role              Role               @default(USER)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  accounts          Account[]
  sessions          Session[]
  months            Month[]
  templates         LineItemTemplate[]
  chitFunds         ChitFund[]
  receivables       Receivable[]
  pushSubscriptions PushSubscription[]
}

// ─── Finance Core ─────────────────────────────────────────────────────────────

enum Category {
  HOUSE_MAINTENANCE
  LOAN
  CHIT_FUND
  CREDIT_CARD
  SAVINGS
  PERSONAL
  MISCELLANEOUS
  SALARY
  FREELANCE
  RENTAL
  BUSINESS
  INVESTMENTS
  OTHER_INCOME
}

enum Frequency {
  MONTHLY
  YEARLY
}

enum TemplateType {
  EXPENSE
  INCOME
}

enum AdHocType {
  INCOME
  EXPENSE
}

// Recurring line item template — one per type of payment
model LineItemTemplate {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  category         Category
  customCategory   String?
  amount           Float
  isFixed          Boolean        @default(true)
  dueDateDay       Int?
  isActive         Boolean        @default(true)
  foreClosedOn     DateTime?
  foreCloseAmount  Float?
  pendingAmount    Float?
  pendingFromMonth Int?
  pendingFromYear  Int?
  statementDay     Int?
  frequency        Frequency      @default(MONTHLY)
  dueMonth         Int?
  templateType     TemplateType   @default(EXPENSE)
  endsOnMonth      Int?
  endsOnYear       Int?
  sortOrder        Int            @default(0)
  loanOriginalPrincipal   Float?
  loanInterestRate        Float?
  loanRateType            String?   // "FIXED" | "FLOATING"
  loanStartDate           DateTime?
  loanOutstandingOverride Float?
  createdAt        DateTime       @default(now())
  entries          MonthlyEntry[]
  chitFund         ChitFund?
}

// One record per calendar month per user
model Month {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  month           Int
  year            Int
  salaryIncome    Float          @default(0)
  freelanceIncome Float          @default(0)
  otherIncome     Float          @default(0)
  isPopulated     Boolean        @default(false)
  createdAt       DateTime       @default(now())
  entries         MonthlyEntry[]
  adHocItems      AdHocItem[]
  receivables     Receivable[]

  @@unique([userId, month, year])
}

// Instance of a template for a specific month
model MonthlyEntry {
  id              String           @id @default(cuid())
  monthId         String
  month           Month            @relation(fields: [monthId], references: [id], onDelete: Cascade)
  templateId      String
  template        LineItemTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  amount          Float
  isPaid          Boolean          @default(false)
  paidOn          DateTime?
  paidAmount      Float?
  cashbackAmount  Float?
  notes           String?
  statementAmount Float?
  createdAt       DateTime         @default(now())

  @@unique([monthId, templateId])
}

// Chit fund details — linked 1:1 to a LineItemTemplate
model ChitFund {
  id                    String           @id @default(cuid())
  templateId            String           @unique
  template              LineItemTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId                String
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalValue            Float
  durationMonths        Int
  startDate             DateTime
  monthlyUnliftedAmount Float
  monthlyLiftedAmount   Float?
  isLifted              Boolean          @default(false)
  liftedOn              DateTime?
  liftedAmount          Float?
  liftedUsedFor         String?
  accumulatedSavings    Float            @default(0)
  endDate               DateTime?
  createdAt             DateTime         @default(now())
}

// One-off income or expense for a month
model AdHocItem {
  id        String    @id @default(cuid())
  monthId   String
  month     Month     @relation(fields: [monthId], references: [id], onDelete: Cascade)
  name      String
  amount    Float
  type      AdHocType
  category  Category?
  date      DateTime
  notes     String?
  createdAt DateTime  @default(now())
}

enum ReceivableCategory {
  INVESTMENT
  PERSONAL_LOAN
  CUSTOM
}

enum ReceivableStatus {
  PENDING
  RECEIVED
}

model Receivable {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        ReceivableCategory
  customCategory  String?
  description     String
  expectedAmount  Float
  expectedDate    DateTime?
  status          ReceivableStatus   @default(PENDING)
  receivedAmount  Float?
  receivedDate    DateTime?
  receivedMonthId String?
  receivedMonth   Month?             @relation(fields: [receivedMonthId], references: [id])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

// Web Push subscription per device
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  label     String?
  createdAt DateTime @default(now())
}
