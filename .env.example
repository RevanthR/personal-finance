# Vercel Postgres — get from Vercel dashboard after adding Postgres storage
DATABASE_URL="postgres://..."

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth — create at https://console.cloud.google.com/
# Authorized redirect: https://your-domain.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Web Push VAPID keys — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:revanth.rallabandi@gmail.com"
